generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
}

enum Dimension {
  WEIGHT
  VOLUME
  COUNT
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String   @id @default(cuid())

  name               String
  sku                String   @unique
  description        String?

  dimension          Dimension

  baseUnit           String

  stockQuantity      Decimal  @db.Decimal(20,8)

  pricePerBaseUnit   Decimal  @db.Decimal(20,8)

  orderItems         OrderItem[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Order {
  id          String        @id @default(cuid())

  userId      String

  user        User          @relation(fields: [userId], references: [id])

  status      OrderStatus   @default(PENDING)

  totalAmount Decimal       @db.Decimal(20,8)

  items       OrderItem[]

  createdAt   DateTime      @default(now())
}

model OrderItem {
  id                String    @id @default(cuid())

  orderId           String
  productId         String

  order             Order     @relation(fields: [orderId], references: [id])

  product           Product   @relation(fields: [productId], references: [id])

  enteredQuantity   Decimal   @db.Decimal(20,8)

  enteredUnit       String

  baseQuantity      Decimal   @db.Decimal(20,8)

  price             Decimal   @db.Decimal(20,8)
}